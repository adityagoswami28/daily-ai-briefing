# Daily AI Briefing - Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# Gmail SMTP Configuration (Required)
# ============================================
# Your Gmail email address
GMAIL_USER=your_email@gmail.com

# Gmail App Password (NOT your regular password!)
# Generate at: Google Account > Security > App passwords
GMAIL_APP_PASSWORD=your_16_char_app_password

# Email recipient (defaults to GMAIL_USER if not set)
RECIPIENT_EMAIL=your_email@gmail.com

# ============================================
# Reddit API (Required for Reddit content)
# ============================================
# Create app at: https://www.reddit.com/prefs/apps
# Choose "script" type application
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=DailyAIBriefing/1.0

# ============================================
# OpenAI API (Required for AI summaries)
# ============================================
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key

# ============================================
# Optional Settings
# ============================================
# Timezone for delivery scheduling
TIMEZONE=America/New_York

# Maximum articles to include in email
MAX_ARTICLES=40

# Maximum age of articles in hours
MAX_AGE_HOURS=72

# ============================================
# Feature Flags (true/false)
# ============================================
# NOTE: RSS feeds from major sites are blocked by Cloudflare
# Recommend keeping RSS disabled and using HackerNews + ArXiv + GitHub instead
INCLUDE_RSS=false
INCLUDE_HACKERNEWS=true
INCLUDE_REDDIT=false
INCLUDE_ARXIV=true
INCLUDE_GITHUB_TRENDING=true
ENABLE_AI_SUMMARY=true

# ============================================
# Topic Filtering (New Feature)
# ============================================
# Enable strict topic-based filtering (only show articles matching topics)
ENABLE_TOPIC_FILTERING=true

# Topics to filter for (comma-separated)
# Only articles mentioning these topics will be included when filtering is enabled
# Example: OpenAI,Claude,Google Gemini,NotebookLM,Apple,MCP Framework,Claude Skills
FILTER_TOPICS= OpenAI,Claude,Google Gemini,NotebookLM,Apple,MCP Framework,Claude Skills,OpenClaw

# ============================================
# GitHub Trending Settings
# ============================================
# Number of days to track repos before allowing repeats
GITHUB_HISTORY_DAYS=30
